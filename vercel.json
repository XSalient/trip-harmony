{
  "version": 2,
  "framework": null,
  "buildCommand": "vite build && node_modules/.bin/esbuild api/server.ts --bundle --platform=node --format=cjs --external:*.node --outfile=api/index.js",
  "installCommand": "pnpm install",
  "outputDirectory": "dist/public",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
